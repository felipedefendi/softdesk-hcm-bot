SOFTDESK_URL=https://js.soft4.com.br/chamado
SOFTDESK_EMAIL=
SOFTDESK_PASSWORD=

# minutos de intervalo entre cada verificacao
POLL_INTERVAL_MINUTES=5

# modo dry-run: so calcula e loga em state/dry-run.log quem seria o
# atendente, nunca atribui o chamado de verdade nem manda Teams. Usado
# durante a validacao do bot rodando na nuvem, em paralelo ao bot real.
DRY_RUN=false

# URL do workflow "Enviar alertas de webhook para um chat" do canal
# "Revezamento de chamados" no Teams (Power Automate)
TEAMS_WEBHOOK_URL=

# webhook de um canal separado, usado pra conferir a aparencia de um card novo
# sem poluir o canal real. So e usado por `npm run relatorio -- --teste`.
TEAMS_WEBHOOK_TESTE_URL=

# dominio dos e-mails corporativos no Teams (Azure AD). Os atendentes em
# state/atendentes.json guardam so o usuario (ex.: "fulano.silva") e este
# dominio e anexado pra formar o UPN da @mention. Vazio = sem mencao.
TEAMS_EMAIL_DOMAIN=empresa.com.br

# porta e senha do dashboard de administracao
DASHBOARD_PORT=3001
DASHBOARD_PASSWORD=
