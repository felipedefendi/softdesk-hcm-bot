{
  "name": "softdesk-hcm-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Automacao para distribuir chamados HCM sem atendente no SoftDesk entre a equipe, em rodizio",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "rodar": "ts-node src/rodar-uma-vez.ts",
    "relatorio": "ts-node src/rodar-relatorio.ts",
    "dashboard": "ts-node src/dashboard/server.ts",
    "build": "tsc",
    "test": "tsc && node --test dist/relatorios/periodos.test.js dist/relatorios/metricas.test.js dist/relatorios/erros.test.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
