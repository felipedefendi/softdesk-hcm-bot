SOFTDESK_URL=https://js.soft4.com.br/chamado
SOFTDESK_EMAIL=
SOFTDESK_PASSWORD=

# minutos de intervalo entre cada verificacao
POLL_INTERVAL_MINUTES=5

# roda com navegador visivel (false) ou em segundo plano (true)
HEADLESS=false

# modo dry-run: so calcula e loga em state/dry-run.log quem seria o
# atendente, nunca atribui o chamado de verdade nem manda Teams. Usado
# durante a validacao do bot rodando na nuvem, em paralelo ao bot real.
DRY_RUN=false

# URL do workflow "Enviar alertas de webhook para um chat" do canal
# "Revezamento de chamados" no Teams (Power Automate)
TEAMS_WEBHOOK_URL=

# porta e senha do dashboard de administracao
DASHBOARD_PORT=3001
DASHBOARD_PASSWORD=
